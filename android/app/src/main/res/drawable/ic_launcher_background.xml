<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Diagonal green gradient background -->
    <path android:pathData="M0,0 L108,0 L108,108 L0,108 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="0"
                android:startY="0"
                android:endX="108"
                android:endY="108">
                <item android:offset="0.0" android:color="#0D5C3D"/>
                <item android:offset="0.5" android:color="#148050"/>
                <item android:offset="1.0" android:color="#1DB869"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Subtle highlight circle (top-left glow) -->
    <path android:pathData="M-10,-10 Q40,20 30,70 Q20,90 -10,60 Z"
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.07"/>

</vector>
